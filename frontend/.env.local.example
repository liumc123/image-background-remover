# =====================================================
# RMBG Frontend Environment Variables
# =====================================================

# API URL for the Worker (change in production)
NEXT_PUBLIC_API_URL=http://localhost:8787

# =====================================================
# Authentication
# =====================================================

# Generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here

# Google OAuth (from Google Cloud Console)
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=GOCSPX-xxxxx

# =====================================================
# PayPal Integration
# =====================================================

# From PayPal Developer Dashboard
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id

# =====================================================
# Cloudflare D1 (for production)
# =====================================================

# Database ID - create with: wrangler d1 create rmbg-users
# Then add binding in wrangler.toml
# D1_DATABASE_ID=your-database-id
